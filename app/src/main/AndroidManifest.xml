<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- İnternet ve Ağ Erişim İzinleri -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Kamera ve Galeri İzinleri -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Android 13 ve altı için galeri izni -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <!-- Android 13 ve üstü için yeni galeri izni -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kombin"
        android:usesCleartextTraffic="true">

        <!-- GİRİŞ EKRANI: Launcher olduğu için exported true kalmalı -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ANA EKRAN: Rotasyon çökmelerini engelleyen tam yapı -->
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize"
            android:exported="true"
            android:launchMode="singleTop">
        </activity>

        <!-- KIYAFET EKLEME EKRANI -->
        <activity
            android:name=".AddClothingActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize"
            android:windowSoftInputMode="adjustPan">
        </activity>

        <!-- KAYIT EKRANI -->
        <activity
            android:name=".RegisterActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize"
            android:windowSoftInputMode="adjustResize">
        </activity>

        <!-- AYARLAR EKRANI -->
        <activity
            android:name=".SettingsActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize">
        </activity>

    </application>

</manifest>