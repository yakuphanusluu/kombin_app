<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"> <!-- Elemanları dikeyde ortalamak için eklendi -->

        <ImageView
            android:id="@+id/ivClothThumbnail"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="#F0F0F0" />

        <!-- Ortadaki yazı kısmı. weight="1" vererek çarpı butonunu en sağa itiyoruz -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvClothDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kıyafet Türü"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvClothColor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Renk"
                android:textColor="#757575" />
        </LinearLayout>

        <!-- YENİ EKLENEN SİLME ÇARPI BUTONU -->
        <ImageButton
            android:id="@+id/btnDeleteClothing"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#D32F2F"
            android:padding="8dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>